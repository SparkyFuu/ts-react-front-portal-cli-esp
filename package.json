{
  "name": "ts-react-front-portal-cli-esp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start:local": "VITE_API_BASE_URL=$(grep '^VITE_API_BASE_URL=' .env.local | cut -d= -f2-) vite --port 3001 --mode local",
    "start:dev": "VITE_API_BASE_URL=$(grep '^VITE_API_BASE_URL=' .env | cut -d= -f2-) vite --port 3001 --mode dev",
    "build:dev": "tsc -b && VITE_API_BASE_URL=$(grep '^VITE_API_BASE_URL=' .env | cut -d= -f2-) vite build --mode dev",
    "build:develop": "npm run build:dev",
    "build:prod": "tsc -b && VITE_API_BASE_URL=$(grep '^VITE_API_BASE_URL=' .env.prod | cut -d= -f2-) vite build --mode prod",
    "build": "npm run build:prod",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.5.1",
    "@reduxjs/toolkit": "^2.10.1",
    "@tailwindcss/vite": "^4.1.17",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.554.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.6",
    "react-select": "^5.10.2",
    "react-toastify": "^11.0.5",
    "recharts": "^3.4.1",
    "redux-persist": "^6.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2"
  }
}
